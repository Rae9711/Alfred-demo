# Backend
BACKEND_PORT=8080
NODE_ENV=production
PORT=8080

# LLM Provider: "claude" | "qwen" | "ollama" (auto-detects if not set)
LLM_PROVIDER=
ANTHROPIC_API_KEY=
QWEN_API_KEY=

# Ollama (fallback when no cloud API key is set)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_PORT=11434

# Google OAuth (Gmail, Calendar, Tasks)
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Brave Search API
BRAVE_SEARCH_API_KEY=

# Kiwi (flight search)
KIWI_API_KEY=

# Supabase (auth & persistence)
SUPABASE_URL=
SUPABASE_KEY=

# WeChatPadPro (WeChat sending/receiving via Docker)
WECHATPADPRO_URL=http://localhost:2531
WECHATPADPRO_TOKEN=
WECHATPADPRO_APP_ID=

# Frontend
FRONTEND_PORT=80
VITE_WS_URL=ws://localhost:8080

# Frontend Supabase (auth — Step 2)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# For production (set these)
# VITE_WS_URL=wss://your-backend-domain.com
# OLLAMA_URL=https://api.openrouter.ai/v1  # or your Ollama API
